# Put your Gemini API key here.
# Get it from Google AI Studio.
GEMINI_API_KEY=your_gemini_api_key_here

# Official docs currently show gemini-3.5-flash in quickstart examples.
# You can change this from AI Studio if your account shows another model.
GEMINI_MODEL=gemini-3.5-flash

# Frontend origins allowed by CORS.
# Vite React usually runs on http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000

# Set true for demo mode without calling Gemini.
MOCK_LLM=false
